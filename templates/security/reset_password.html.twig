{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — Administration{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4"
     style="background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-accent) 100%);">

    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold tracking-tight" style="color: var(--color-primary-dark);">
                Les Délices de Chloé
            </h1>
            <p class="mt-2 text-sm" style="color: var(--color-text); opacity: 0.6;">
                Choisir un nouveau mot de passe
            </p>
        </div>

        <div class="card p-8">

            {# Erreurs de validation #}
            {% if errors is not empty %}
                <div class="mb-4 p-3 rounded-lg text-sm text-red-800 bg-red-100 border border-red-200">
                    {% for error in errors %}
                        <p>{{ error }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            <form method="post" novalidate>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password_' ~ token) }}">

                <div class="mb-5">
                    <label for="password" class="block text-sm font-medium mb-1"
                           style="color: var(--color-text);">
                        Nouveau mot de passe
                    </label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        autocomplete="new-password"
                        required
                        autofocus
                        placeholder="8 caractères minimum"
                        class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all"
                        style="border-color: var(--color-secondary); background: var(--color-bg);
                               color: var(--color-text);"
                        onfocus="this.style.borderColor='var(--color-primary)'"
                        onblur="this.style.borderColor='var(--color-secondary)'"
                    >
                </div>

                <div class="mb-6">
                    <label for="confirm_password" class="block text-sm font-medium mb-1"
                           style="color: var(--color-text);">
                        Confirmer le mot de passe
                    </label>
                    <input
                        type="password"
                        id="confirm_password"
                        name="confirm_password"
                        autocomplete="new-password"
                        required
                        placeholder="Répétez le mot de passe"
                        class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all"
                        style="border-color: var(--color-secondary); background: var(--color-bg);
                               color: var(--color-text);"
                        onfocus="this.style.borderColor='var(--color-primary)'"
                        onblur="this.style.borderColor='var(--color-secondary)'"
                    >
                </div>

                {# Indicateur de force du mot de passe #}
                <div class="mb-6">
                    <div class="flex gap-1 h-1">
                        <div id="str-1" class="flex-1 rounded-full bg-gray-200"></div>
                        <div id="str-2" class="flex-1 rounded-full bg-gray-200"></div>
                        <div id="str-3" class="flex-1 rounded-full bg-gray-200"></div>
                        <div id="str-4" class="flex-1 rounded-full bg-gray-200"></div>
                    </div>
                    <p id="str-label" class="text-xs mt-1 opacity-50" style="color: var(--color-text);"></p>
                </div>

                <button type="submit"
                        class="btn-primary w-full py-3 rounded-xl text-sm font-semibold tracking-wide">
                    Enregistrer le nouveau mot de passe
                </button>
            </form>

        </div>

        <p class="text-center mt-6 text-xs opacity-40" style="color: var(--color-text);">
            <a href="{{ path('app_login') }}" class="hover:underline">← Retour à la connexion</a>
        </p>

    </div>
</div>

<script>
document.getElementById('password').addEventListener('input', function () {
    const val = this.value;
    let score = 0;
    if (val.length >= 8)  score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;

    const colors = ['', '#ef4444', '#f97316', '#eab308', '#22c55e'];
    const labels = ['', 'Trop court', 'Faible', 'Moyen', 'Fort'];
    for (let i = 1; i <= 4; i++) {
        const el = document.getElementById('str-' + i);
        el.style.background = i <= score ? colors[score] : '#e5e7eb';
    }
    document.getElementById('str-label').textContent = val.length ? labels[score] : '';
});
</script>
{% endblock %}
