{% extends 'base.html.twig' %}

{% block title %}Connexion — Administration{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4"
     style="background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-accent) 100%);">

    <div class="w-full max-w-md">

        {# Logo / Titre #}
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold tracking-tight" style="color: var(--color-primary-dark);">
                Les Délices de Chloé
            </h1>
            <p class="mt-2 text-sm" style="color: var(--color-text); opacity: 0.6;">
                Espace administration
            </p>
        </div>

        {# Carte de connexion #}
        <div class="card p-8">

            {# Messages flash #}
            {% for message in app.flashes('success') %}
                <div class="mb-4 p-3 rounded-lg text-sm text-green-800 bg-green-100 border border-green-200">
                    {{ message }}
                </div>
            {% endfor %}

            {# Erreur d'authentification #}
            {% if error %}
                <div class="mb-4 p-3 rounded-lg text-sm text-red-800 bg-red-100 border border-red-200">
                    Identifiant ou mot de passe incorrect.
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}" novalidate>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="mb-5">
                    <label for="username" class="block text-sm font-medium mb-1"
                           style="color: var(--color-text);">
                        Identifiant
                    </label>
                    <input
                        type="text"
                        id="username"
                        name="_username"
                        value="{{ last_username }}"
                        autocomplete="username"
                        required
                        autofocus
                        class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all"
                        style="border-color: var(--color-secondary); background: var(--color-bg);
                               color: var(--color-text);"
                        onfocus="this.style.borderColor='var(--color-primary)'"
                        onblur="this.style.borderColor='var(--color-secondary)'"
                    >
                </div>

                <div class="mb-2">
                    <label for="password" class="block text-sm font-medium mb-1"
                           style="color: var(--color-text);">
                        Mot de passe
                    </label>
                    <div class="relative">
                        <input
                            type="password"
                            id="password"
                            name="_password"
                            autocomplete="current-password"
                            required
                            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all"
                            style="border-color: var(--color-secondary); background: var(--color-bg);
                                   color: var(--color-text);"
                            onfocus="this.style.borderColor='var(--color-primary)'"
                            onblur="this.style.borderColor='var(--color-secondary)'"
                        >
                        {# Toggle visibilité mot de passe #}
                        <button type="button"
                                onclick="togglePwd()"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-xs opacity-50 hover:opacity-100">
                            <span id="pwd-eye">👁</span>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between mb-6">
                    <label class="flex items-center gap-2 text-sm cursor-pointer"
                           style="color: var(--color-text); opacity: 0.7;">
                        <input type="checkbox" name="_remember_me" class="rounded">
                        Se souvenir de moi
                    </label>
                    <a href="{{ path('app_forgot_password_request') }}"
                       class="text-sm hover:underline"
                       style="color: var(--color-primary);">
                        Mot de passe oublié ?
                    </a>
                </div>

                <button type="submit"
                        class="btn-primary w-full py-3 rounded-xl text-sm font-semibold tracking-wide
                               focus:outline-none focus:ring-2"
                        style="--tw-ring-color: var(--color-primary);">
                    Se connecter
                </button>
            </form>
        </div>

        <p class="text-center mt-6 text-xs opacity-40" style="color: var(--color-text);">
            <a href="{{ path('app_home') }}" class="hover:underline">← Retour au site</a>
        </p>

    </div>
</div>

<script>
function togglePwd() {
    const input = document.getElementById('password');
    input.type = input.type === 'password' ? 'text' : 'password';
}
</script>
{% endblock %}
