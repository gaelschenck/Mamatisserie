{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — Administration{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4"
     style="background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-accent) 100%);">

    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold tracking-tight" style="color: var(--color-primary-dark);">
                Les Délices de Chloé
            </h1>
            <p class="mt-2 text-sm" style="color: var(--color-text); opacity: 0.6;">
                Réinitialisation du mot de passe
            </p>
        </div>

        <div class="card p-8">

            {% if message_sent %}
                {# Message générique — ne révèle pas si l'email existe #}
                <div class="text-center">
                    <div class="text-4xl mb-4">📬</div>
                    <h2 class="text-lg font-semibold mb-2" style="color: var(--color-primary-dark);">
                        Email envoyé !
                    </h2>
                    <p class="text-sm mb-6" style="color: var(--color-text); opacity: 0.7;">
                        Si un compte est associé à cette adresse, vous recevrez un lien de
                        réinitialisation valable <strong>1 heure</strong>. Pensez à vérifier
                        vos spams.
                    </p>
                    <a href="{{ path('app_login') }}"
                       class="btn-primary inline-block px-6 py-3 rounded-xl text-sm font-semibold">
                        Retour à la connexion
                    </a>
                </div>

            {% else %}
                <h2 class="text-lg font-semibold mb-1" style="color: var(--color-primary-dark);">
                    Mot de passe oublié ?
                </h2>
                <p class="text-sm mb-6" style="color: var(--color-text); opacity: 0.6;">
                    Saisissez votre adresse email pour recevoir un lien de réinitialisation.
                </p>

                <form method="post" novalidate>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">

                    <div class="mb-6">
                        <label for="email" class="block text-sm font-medium mb-1"
                               style="color: var(--color-text);">
                            Adresse email
                        </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            autocomplete="email"
                            required
                            autofocus
                            placeholder="votre@email.fr"
                            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-all"
                            style="border-color: var(--color-secondary); background: var(--color-bg);
                                   color: var(--color-text);"
                            onfocus="this.style.borderColor='var(--color-primary)'"
                            onblur="this.style.borderColor='var(--color-secondary)'"
                        >
                    </div>

                    <button type="submit"
                            class="btn-primary w-full py-3 rounded-xl text-sm font-semibold tracking-wide">
                        Envoyer le lien
                    </button>
                </form>
            {% endif %}

        </div>

        <p class="text-center mt-6 text-xs opacity-40" style="color: var(--color-text);">
            <a href="{{ path('app_login') }}" class="hover:underline">← Retour à la connexion</a>
        </p>

    </div>
</div>
{% endblock %}
