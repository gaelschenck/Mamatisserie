{% extends 'admin/base_admin.html.twig' %}
{% block title %}Modifier le compte {{ user.username }}{% endblock %}

{% block main %}

<div class="mb-6">
    <a href="{{ path('admin_user_index') }}" class="text-sm opacity-50 hover:opacity-80">
        ← Retour aux comptes
    </a>
    <h1 class="text-xl font-bold mt-2" style="color: var(--color-primary-dark);">
        Modifier : {{ user.username }}
    </h1>
</div>

<div class="max-w-md">
    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

        {% include 'admin/_form_errors.html.twig' %}

        <div>
            {{ form_label(form.username, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
            {{ form_widget(form.username, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
            {{ form_errors(form.username) }}
        </div>

        <div>
            {{ form_label(form.email, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
            {{ form_widget(form.email, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="rounded-xl border px-4 py-3 text-sm opacity-60"
             style="border-color: var(--color-secondary); background: var(--color-bg-alt);">
            🔒 Pour changer le mot de passe, utilisez
            <a href="{{ path('app_forgot_password_request') }}" class="underline" target="_blank">
                "Mot de passe oublié"
            </a>.
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="btn-primary px-6 py-3 rounded-xl font-semibold text-sm">
                Enregistrer
            </button>
            <a href="{{ path('admin_user_index') }}"
               class="px-6 py-3 rounded-xl text-sm border hover:opacity-70 transition-opacity"
               style="border-color: var(--color-secondary); color: var(--color-text);">
                Annuler
            </a>
        </div>

    {{ form_end(form) }}
</div>

{% endblock %}
