{% extends 'admin/base_admin.html.twig' %}
{% block title %}Tableau de bord{% endblock %}

{% block main %}

<div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold" style="color: var(--color-primary-dark);">
        Bonjour {{ app.user.username }} 👋
    </h1>
    <a href="{{ path('admin_product_new') }}" class="btn-primary px-5 py-2.5 rounded-xl text-sm font-semibold">
        + Nouveau produit
    </a>
</div>

{# ── Statistiques ───────────────────────────────────────────────── #}
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">

    <div class="rounded-2xl p-5 border" style="background: var(--color-bg-alt); border-color: var(--color-secondary);">
        <p class="text-3xl font-bold" style="color: var(--color-primary-dark);">{{ totalProducts }}</p>
        <p class="text-sm mt-1 opacity-60">Produits total</p>
    </div>

    <div class="rounded-2xl p-5 border" style="background: var(--color-bg-alt); border-color: var(--color-secondary);">
        <p class="text-3xl font-bold text-green-600">{{ totalVisible }}</p>
        <p class="text-sm mt-1 opacity-60">Produits visibles</p>
    </div>

    <div class="rounded-2xl p-5 border" style="background: var(--color-bg-alt); border-color: var(--color-secondary);">
        <p class="text-3xl font-bold" style="color: var(--color-primary);">{{ totalFeatured }}</p>
        <p class="text-sm mt-1 opacity-60">Coups de cœur</p>
    </div>

    <div class="rounded-2xl p-5 border" style="background: var(--color-bg-alt); border-color: var(--color-secondary);">
        <p class="text-3xl font-bold" style="color: var(--color-primary-dark);">{{ totalCategories }}</p>
        <p class="text-sm mt-1 opacity-60">Catégories</p>
    </div>

</div>

{# ── Top produits vus ───────────────────────────────────────────── #}
{% if topViewed is not empty %}
<div class="rounded-2xl border overflow-hidden" style="border-color: var(--color-secondary);">
    <div class="px-5 py-4 border-b flex items-center justify-between"
         style="background: var(--color-bg-alt); border-color: var(--color-secondary);">
        <h2 class="font-semibold text-sm" style="color: var(--color-primary-dark);">
            👁️ Top 5 produits consultés
        </h2>
    </div>
    <div class="divide-y" style="divide-color: var(--color-secondary);">
        {% for product in topViewed %}
        <div class="flex items-center justify-between px-5 py-3 text-sm">
            <div class="flex items-center gap-3">
                {% if product.photo %}
                <img src="/uploads/products/{{ product.photo }}" alt=""
                     class="w-9 h-9 rounded-lg object-cover flex-shrink-0">
                {% else %}
                <div class="w-9 h-9 rounded-lg flex items-center justify-center text-lg"
                     style="background: var(--color-bg-alt);">🍰</div>
                {% endif %}
                <span style="color: var(--color-text);">{{ product.name }}</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="font-semibold opacity-70" style="color: var(--color-text);">
                    {{ product.viewCount }} vue{{ product.viewCount > 1 ? 's' : '' }}
                </span>
                <a href="{{ path('admin_product_edit', {id: product.id}) }}"
                   class="text-xs underline opacity-40 hover:opacity-80">
                    Modifier
                </a>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{% endblock %}
