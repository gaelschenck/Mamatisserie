{% extends 'admin/base_admin.html.twig' %}
{% block title %}{{ isNew ? 'Nouvelle sous-catégorie' : 'Modifier ' ~ subCategory.name }}{% endblock %}

{% block main %}

<div class="mb-6">
    <a href="{{ path('admin_subcategory_index') }}" class="text-sm opacity-50 hover:opacity-80">
        ← Retour aux sous-catégories
    </a>
    <h1 class="text-xl font-bold mt-2" style="color: var(--color-primary-dark);">
        {{ isNew ? '+ Nouvelle sous-catégorie' : 'Modifier : ' ~ subCategory.name }}
    </h1>
</div>

<div class="max-w-lg">
    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

        {% include 'admin/_form_errors.html.twig' %}

        <div>
            {{ form_label(form.name, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
            {{ form_widget(form.name, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
            {{ form_errors(form.name) }}
        </div>

        <div>
            {{ form_label(form.category, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
            {{ form_widget(form.category, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
            {{ form_errors(form.category) }}
        </div>

        <div class="flex items-center gap-6">
            <div class="flex-1">
                {{ form_label(form.position, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.position, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
            </div>
            <div class="flex items-center gap-2 pt-5">
                {{ form_widget(form.isVisible) }}
                {{ form_label(form.isVisible, null, {label_attr: {class: 'text-sm cursor-pointer'}}) }}
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="btn-primary px-6 py-3 rounded-xl font-semibold text-sm">
                {{ isNew ? 'Créer' : 'Enregistrer' }}
            </button>
            <a href="{{ path('admin_subcategory_index') }}"
               class="px-6 py-3 rounded-xl text-sm border hover:opacity-70 transition-opacity"
               style="border-color: var(--color-secondary); color: var(--color-text);">
                Annuler
            </a>
        </div>

    {{ form_end(form) }}
</div>

{% endblock %}
