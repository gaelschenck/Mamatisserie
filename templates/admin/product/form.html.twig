{% extends 'admin/base_admin.html.twig' %}
{% block title %}{{ isNew ? 'Nouveau produit' : 'Modifier ' ~ product.name }}{% endblock %}

{% block main %}

<div class="mb-6">
    <a href="{{ path('admin_product_index') }}" class="text-sm opacity-50 hover:opacity-80">
        ← Retour aux produits
    </a>
    <h1 class="text-xl font-bold mt-2" style="color: var(--color-primary-dark);">
        {{ isNew ? '+ Nouveau produit' : 'Modifier : ' ~ product.name }}
    </h1>
</div>

<div class="max-w-2xl">
    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate', enctype: 'multipart/form-data'}}) }}

        {% include 'admin/_form_errors.html.twig' %}

        {# Nom #}
        <div>
            {{ form_label(form.name, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
            {{ form_widget(form.name, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
            {{ form_errors(form.name) }}
        </div>

        {# Description #}
        <div>
            {{ form_label(form.description, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
            {{ form_widget(form.description, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none resize-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
            {{ form_errors(form.description) }}
        </div>

        {# Photo actuelle + upload #}
        <div class="rounded-2xl border p-4" style="border-color: var(--color-secondary); background: var(--color-bg-alt);">
            {{ form_label(form.photoFile, null, {label_attr: {class: 'block text-sm font-medium mb-3'}}) }}
            {% if not isNew and product.photo %}
            <div class="mb-3">
                <img src="/uploads/products/{{ product.photo }}" alt="{{ product.name }}"
                     class="h-32 w-32 object-cover rounded-xl border"
                     style="border-color: var(--color-secondary);">
            </div>
            {% endif %}
            {{ form_widget(form.photoFile) }}
            {{ form_errors(form.photoFile) }}
        </div>

        {# Catégorie + Sous-catégorie #}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.category, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.category, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
                {{ form_errors(form.category) }}
            </div>
            <div>
                {{ form_label(form.subCategory, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.subCategory, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
            </div>
        </div>

        {# Ordre d'affichage #}
        <div class="max-w-xs">
            {{ form_label(form.displayOrder, null, {label_attr: {class: 'block text-sm font-medium mb-1'}}) }}
            {{ form_widget(form.displayOrder, {attr: {class: 'w-full rounded-xl border px-4 py-3 text-sm outline-none', style: 'border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);'}}) }}
        </div>

        {# Options #}
        <div class="flex flex-wrap gap-6">
            <label class="flex items-center gap-2 cursor-pointer">
                {{ form_widget(form.isVisible) }}
                <span class="text-sm">{{ form_label(form.isVisible) }}</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
                {{ form_widget(form.isFeatured) }}
                <span class="text-sm">{{ form_label(form.isFeatured) }}</span>
            </label>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="btn-primary px-6 py-3 rounded-xl font-semibold text-sm">
                {{ isNew ? 'Créer' : 'Enregistrer' }}
            </button>
            <a href="{{ path('admin_product_index') }}"
               class="px-6 py-3 rounded-xl text-sm border hover:opacity-70 transition-opacity"
               style="border-color: var(--color-secondary); color: var(--color-text);">
                Annuler
            </a>
        </div>

    {{ form_end(form) }}
</div>

{% endblock %}
