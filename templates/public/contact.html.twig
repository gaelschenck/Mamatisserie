{% extends 'base.html.twig' %}

{% block title %}Contact — Les Délices de Chloé{% endblock %}
{% block meta_description %}Contactez-moi pour toute commande ou renseignement sur mes créations pâtissières.{% endblock %}

{% block body %}

{% include 'components/navbar.html.twig' %}

<div class="max-w-2xl mx-auto px-4 py-14">

    <h1 class="text-3xl font-bold mb-2 text-center" style="color: var(--color-primary-dark);">
        Me contacter
    </h1>
    <p class="text-center text-sm mb-10 opacity-60" style="color: var(--color-text);">
        Pour toute commande ou renseignement, je vous répondrai dans les plus brefs délais.
    </p>

    {# ── Messages flash ─────────────────────────────────────── #}
    {% for msg in app.flashes('success') %}
    <div class="rounded-xl px-5 py-4 mb-6 text-sm font-medium text-green-800 bg-green-50 border border-green-200">
        ✅ {{ msg }}
    </div>
    {% endfor %}

    {% for msg in app.flashes('error') %}
    <div class="rounded-xl px-5 py-4 mb-6 text-sm font-medium text-red-800 bg-red-50 border border-red-200">
        ❌ {{ msg }}
    </div>
    {% endfor %}

    {# ── Pré-remplissage depuis un produit ──────────────────── #}
    {% if productName %}
    <div class="rounded-xl px-5 py-3 mb-6 text-sm border" style="border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text);">
        📌 Demande concernant : <strong>{{ productName }}</strong>
    </div>
    {% endif %}

    {# ── Formulaire ─────────────────────────────────────────── #}
    <form method="post" action="{{ path('app_contact') }}" class="space-y-5"
          novalidate>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('contact') }}">
        {% if productName %}
        <input type="hidden" name="product_name" value="{{ productName }}">
        {% endif %}

        {# Nom #}
        <div>
            <label for="name" class="block text-sm font-medium mb-1" style="color: var(--color-text);">
                Votre nom <span class="text-red-500">*</span>
            </label>
            <input type="text" id="name" name="name"
                   value="{{ formData.name ?? '' }}"
                   required
                   class="w-full rounded-xl border px-4 py-3 text-sm outline-none transition-all focus:ring-2"
                   style="border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text); --tw-ring-color: var(--color-primary);">
        </div>

        {# Email #}
        <div>
            <label for="email" class="block text-sm font-medium mb-1" style="color: var(--color-text);">
                Votre e-mail <span class="text-red-500">*</span>
            </label>
            <input type="email" id="email" name="email"
                   value="{{ formData.email ?? '' }}"
                   required
                   class="w-full rounded-xl border px-4 py-3 text-sm outline-none transition-all focus:ring-2"
                   style="border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text); --tw-ring-color: var(--color-primary);">
        </div>

        {# Sujet #}
        <div>
            <label for="subject" class="block text-sm font-medium mb-1" style="color: var(--color-text);">
                Sujet <span class="text-red-500">*</span>
            </label>
            <input type="text" id="subject" name="subject"
                   value="{{ formData.subject ?? (productName ? 'Demande concernant : ' ~ productName : '') }}"
                   required
                   class="w-full rounded-xl border px-4 py-3 text-sm outline-none transition-all focus:ring-2"
                   style="border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text); --tw-ring-color: var(--color-primary);">
        </div>

        {# Message #}
        <div>
            <label for="message" class="block text-sm font-medium mb-1" style="color: var(--color-text);">
                Message <span class="text-red-500">*</span>
            </label>
            <textarea id="message" name="message" rows="6" required
                      class="w-full rounded-xl border px-4 py-3 text-sm outline-none transition-all focus:ring-2 resize-none"
                      style="border-color: var(--color-secondary); background: var(--color-bg-alt); color: var(--color-text); --tw-ring-color: var(--color-primary);">{{ formData.message ?? '' }}</textarea>
        </div>

        <button type="submit"
                class="btn-primary w-full py-3 rounded-xl font-semibold transition-all hover:opacity-90">
            Envoyer mon message
        </button>
    </form>

</div>

{% include 'components/footer.html.twig' %}

{% endblock %}
